# Copy to .env and fill in. For Netlify, set these in Site configuration → Environment variables.
# See docs/ENV-VARIABLES-AND-NETLIFY.md for the full list and where each is used.

# Supabase (frontend: auth, survey, chat storage)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional backend vars (Netlify/server)
# GROQ_API_KEY=your-groq-api-key
# OPENAI_API_KEY=your-openai-api-key
# TRANSCRIBE_PROVIDER=openai
