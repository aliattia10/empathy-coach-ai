# Copy to .env and fill in. For Netlify, set these in Site configuration → Environment variables.
# See docs/ENV-VARIABLES-AND-NETLIFY.md for the full list and where each is used.

# Supabase (frontend: auth, survey, chat storage)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional backend vars (Netlify/server — chat uses RunPod, not Groq)
# VLLM_API_URL=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID/openai/v1/chat/completions
# LLM_API_KEY=your-runpod-api-key
# VLLM_MODEL=empathy-coach-qwen
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
