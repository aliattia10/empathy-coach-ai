# Choose which provider your local server uses: openrouter (default) or groq
LLM_PROVIDER=openrouter

# OpenRouter
# 1. Sign up at https://openrouter.ai and create an API key
# 2. Set the key below. Leave URL/model as-is to use a free model (rate-limited).
VLLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=your-openrouter-api-key

# Free models are often rate-limited upstream; switch models or use BYOK for reliability.
VLLM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Groq (OpenAI-compatible)
# 1. Create a Groq API key
# 2. Set LLM_PROVIDER=groq and fill these values
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Optional: generation parameters
# VLLM_TEMPERATURE=0.7
# VLLM_MAX_TOKENS=500
# VLLM_TIMEOUT_MS=60000

# Optional: server port (default 3001)
# PORT=3001
