# OpenRouter (free tier: ~20 req/min, 200 req/day — no card required)
# 1. Sign up at https://openrouter.ai and create an API key
# 2. Set the key below. Leave URL/model as-is to use free LLM.
VLLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=your-openrouter-api-key

# Free model (append :free for no cost). Other free options: google/gemma-3-4b-it:free, openrouter/free
VLLM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Optional: generation parameters
# VLLM_TEMPERATURE=0.7
# VLLM_MAX_TOKENS=500
# VLLM_TIMEOUT_MS=60000

# Optional: server port (default 3001)
# PORT=3001
