# RunPod Serverless vLLM (production chat — no Groq)
# Endpoint ID: RunPod → Serverless → your endpoint → copy from URL or Overview
VLLM_API_URL=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID/openai/v1/chat/completions
LLM_API_KEY=your-runpod-api-key
VLLM_MODEL=empathy-coach-qwen

# Optional: generation parameters (RunPod cold start: use longer timeout)
# VLLM_TEMPERATURE=0.55
# VLLM_MAX_TOKENS=500
# VLLM_TIMEOUT_MS=180000
# VLLM_MAX_CONTEXT_TOKENS=6144
# VLLM_REPETITION_PENALTY=1.12
# RUNPOD_ASYNC=true

# Supabase (trainer feedback injection in system prompt)
# SUPABASE_URL=https://wxxwxvauseqftyorhkkp.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Voice transcription disabled unless you add OPENAI_API_KEY
# TRANSCRIBE_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key

# Optional: server port (default 3001)
# PORT=3001
